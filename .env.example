# Copy to .env and adjust for local use. No value here is a real secret.
#
# Cloud provider variables are listed for completeness (BedrockProvider /
# FoundryProvider are fully implemented — see docs/adr/0001) but are never
# read by anything in docker-compose or CI in this repository. Setting them
# does NOT make this project call AWS/Azure; policies/routing.yaml would also
# need editing, and that is a deliberate, separate, out-of-repo step.

AEGIS_ENVIRONMENT=local

AEGIS_DATABASE_URL=postgresql+asyncpg://aegis:aegis@localhost:5432/aegis
AEGIS_REDIS_URL=redis://localhost:6379/0

AEGIS_OLLAMA_BASE_URL=http://localhost:11434
AEGIS_OLLAMA_DEFAULT_MODEL=llama3.1:8b
AEGIS_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Cloud providers: unused in this repo, present for shape only ---
AEGIS_AWS_REGION=us-east-1
AEGIS_AZURE_AI_FOUNDRY_ENDPOINT=
AEGIS_AZURE_OPENAI_API_VERSION=2024-10-21

AEGIS_OTEL_EXPORTER_OTLP_ENDPOINT=
AEGIS_OTEL_SERVICE_NAME=aegis-gateway

# Dev-only signing key. Real deployments must inject this via a secret
# manager, never commit a real value.
AEGIS_JWT_SIGNING_KEY=dev-only-not-a-secret-change-in-env
AEGIS_JWT_ALGORITHM=HS256
