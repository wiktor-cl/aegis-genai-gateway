# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
build/
dist/
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage

# Env / secrets
.env
*.local.env

# Eval-gate reports (generated by `python -m aegis.eval.cli`)
eval-report.json

# Node / console
console/node_modules/
console/dist/
console/.vite/

# IaC
infra/terraform/**/.terraform/
infra/terraform/**/*.tfstate
infra/terraform/**/*.tfstate.*
# .terraform.lock.hcl is intentionally NOT ignored — this is a root
# configuration (never a reusable module), and Terraform's own guidance is
# to commit the lock file for root configs so `terraform init` is
# reproducible in CI.
infra/bicep/**/*.json.bak
# Compiled ARM JSON (`bicep build` output) is a regenerable artifact, not
# committed — but bicepconfig.json (source, hand-written) must be tracked.
infra/bicep/**/*.json
!infra/bicep/**/bicepconfig.json
!infra/bicep/**/*.parameters.json

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
